# =============================================================================
# AI JOB APPLICATION SYSTEM - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Option 1: Single DATABASE_URL (recommended for production)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/job_application_db

# Option 2: Individual database parameters (alternative)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_NAME=job_application_db

# -----------------------------------------------------------------------------
# AI API KEYS (COST-OPTIMIZED MODE)
# -----------------------------------------------------------------------------

# Google Gemini API Key (REQUIRED - Handles all AI tasks)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude API Key (OPTIONAL - Not used in cost-optimized mode)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# Uncomment above if you want to switch to original architecture

# -----------------------------------------------------------------------------
# MCP INTEGRATIONS
# -----------------------------------------------------------------------------

# Apify API Key (for job scraping)
# Get from: https://console.apify.com/account/integrations
APIFY_API_KEY=apify_api_your-key-here

# Gmail API OAuth Credentials (for email sending)
# Get from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------

# Application environment (development, production)
APP_ENV=development

# API server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# SECURITY & RATE LIMITING
# -----------------------------------------------------------------------------

# Default daily application limit (per constitution.md 5.4)
DEFAULT_DAILY_LIMIT=20

# JWT Secret (for future authentication)
# JWT_SECRET=your-random-secret-key-here

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
# LOG_FILE=/var/log/job_application_system.log

# -----------------------------------------------------------------------------
# OPTIONAL: FILE STORAGE
# -----------------------------------------------------------------------------

# Directory for storing CV files
CV_STORAGE_PATH=./storage/cvs

# Directory for storing generated documents
OUTPUT_STORAGE_PATH=./storage/output

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. As per execution_plan.md: All API keys MUST be loaded from environment
# 2. No credentials should be stored in source code or database
# 3. If any required variable is missing → system will abort on startup
# 4. See README.md for detailed setup instructions
# =============================================================================
